---
/**
 * Card surface with consistent padding, border, and (optional) hover lift.
 *
 *   <Card> ... </Card>
 *   <Card interactive padding="lg" href="/product"> ... </Card>
 */
interface Props {
   tone?: "default" | "elevated" | "brand";
   padding?: "sm" | "md" | "lg" | "none";
   interactive?: boolean;
   href?: string;
   class?: string;
   as?: string;
}
const {
   tone = "default",
   padding = "md",
   interactive = false,
   href,
   class: className,
   as,
}: Props = Astro.props;

const base =
   "block rounded-xl border transition-all duration-300 ease-out " +
   "relative overflow-hidden";

const tones: Record<NonNullable<Props["tone"]>, string> = {
   default: "bg-card border-border-subtle",
   elevated: "bg-panel border-border shadow-sm",
   brand:
      "bg-card border-border-brand " +
      "[background-image:linear-gradient(180deg,rgba(52,213,176,0.04),transparent_60%)]",
};

const paddings: Record<NonNullable<Props["padding"]>, string> = {
   none: "p-0",
   sm: "p-4",
   md: "p-6 sm:p-7",
   lg: "p-8 sm:p-10",
};

const interactiveStyles = interactive
   ? "hover:bg-card-hover hover:border-border-strong hover:-translate-y-0.5 hover:shadow-md cursor-pointer"
   : "";

const Tag = (href ? "a" : as ?? "div") as keyof HTMLElementTagNameMap;
---

<Tag
   href={href}
   class:list={[
      base,
      tones[tone],
      paddings[padding],
      interactiveStyles,
      "no-style",
      className,
   ]}
>
   <slot />
</Tag>
