---
/**
 * Site footer — three-column nav + newsletter + brand strip. Replaces the
 * legacy Qwik Footer. The newsletter form POSTs to /api/mail.json via a tiny
 * inline script.
 */
import Container from "./Container.astro";
import Heading from "./Heading.astro";
import Eyebrow from "./Eyebrow.astro";
import Button from "./Button.astro";
import Logo from "./Logo.astro";

const product = [
   { name: "Product", href: "/product" },
   { name: "Pricing", href: "/pricing" },
   { name: "Community", href: "/community" },
   { name: "Documentation", href: "/docs/introduction/setup" },
];
const company = [
   { name: "Company", href: "/company" },
   { name: "Resources", href: "/resources" },
   { name: "Terms & Privacy", href: "/terms" },
   { name: "Compliance", href: "/compliance" },
   { name: "Contact", href: "mailto:contact@nativelink.com" },
];

const year = new Date().getFullYear();
---

<footer class="relative border-t border-border-subtle bg-bg">
   {/* ── CTA strip ───────────────────────────────────────────────────── */}
   <div
      class="
         relative overflow-hidden
         [background-image:radial-gradient(ellipse_70%_120%_at_50%_0%,rgba(52,213,176,0.10),transparent_60%)]
      "
   >
      <Container width="default">
         <div class="py-20 sm:py-24 flex flex-col items-start gap-8">
            <Eyebrow>Ship faster</Eyebrow>
            <Heading as="h2" size="h1" class="max-w-3xl">
               Let's build at the speed your code is being written.
            </Heading>
            <p class="text-lead text-fg-muted max-w-xl">
               Open source. Free cloud tier. Self-host the moment your team is
               ready.
            </p>
            <div class="flex flex-wrap items-center gap-3">
               <Button
                  href="/docs/introduction/setup#-quickstart"
                  variant="primary"
                  size="lg"
                  arrow
               >
                  Get started
               </Button>
               <Button href="/pricing" variant="secondary" size="lg">
                  See pricing
               </Button>
            </div>
         </div>
      </Container>
   </div>

   {/* ── Hairline divider ────────────────────────────────────────────── */}
   <div class="hairline"></div>

   {/* ── Link columns + newsletter ───────────────────────────────────── */}
   <Container width="default">
      <div
         class="
            py-16 sm:py-20
            grid grid-cols-2 sm:grid-cols-4 gap-10 sm:gap-8
         "
      >
         {/* Brand mark + tagline */}
         <div class="col-span-2 sm:col-span-1 flex flex-col gap-4">
            <a
               href="/"
               class="no-style inline-flex items-center"
               aria-label="NativeLink home"
            >
               <Logo size="md" />
            </a>
            <p class="text-sm text-fg-muted max-w-[18rem]">
               Open source remote build execution and caching, engineered for
               infrastructure-scale teams.
            </p>
         </div>

         {/* Product column */}
         <nav aria-label="Product">
            <p class="text-eyebrow mb-4">Product</p>
            <ul class="flex flex-col gap-2.5">
               {
                  product.map((link) => (
                     <li>
                        <a
                           href={link.href}
                           class="no-style text-sm text-fg-muted hover:text-fg transition-colors"
                        >
                           {link.name}
                        </a>
                     </li>
                  ))
               }
            </ul>
         </nav>

         {/* Company column */}
         <nav aria-label="Company">
            <p class="text-eyebrow mb-4">Company</p>
            <ul class="flex flex-col gap-2.5">
               {
                  company.map((link) => (
                     <li>
                        <a
                           href={link.href}
                           class="no-style text-sm text-fg-muted hover:text-fg transition-colors"
                        >
                           {link.name}
                        </a>
                     </li>
                  ))
               }
            </ul>
         </nav>

         {/* Newsletter */}
         <div class="col-span-2 sm:col-span-1">
            <p class="text-eyebrow mb-4">Newsletter</p>
            <p class="text-sm text-fg-muted mb-4">
               Build performance, deep-tech write-ups, occasionally.
            </p>
            <form id="footer-newsletter" class="flex flex-col gap-3" novalidate>
               <label for="footer-email" class="sr-only">Email address</label>
               <input
                  id="footer-email"
                  name="email"
                  type="email"
                  inputmode="email"
                  autocomplete="email"
                  required
                  placeholder="you@example.com"
                  class="
                     w-full h-10 px-3 rounded-md text-sm
                     bg-card text-fg placeholder:text-fg-subtle
                     border border-border-subtle
                     focus:border-border-brand focus:outline-none focus:ring-2 focus:ring-[color:var(--color-focus-ring)]
                     transition-colors
                  "
               />
               <button
                  type="submit"
                  class="
                     no-style inline-flex h-10 items-center justify-center rounded-md
                     bg-brand text-fg-on-brand text-sm font-medium px-4
                     hover:bg-brand-300 transition-colors
                     focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-focus-ring)]
                  "
               >
                  Subscribe
               </button>
               <p
                  id="footer-newsletter-msg"
                  class="text-xs min-h-[1rem]"
                  aria-live="polite"
               ></p>
            </form>
         </div>
      </div>
   </Container>

   {/* ── Bottom bar ──────────────────────────────────────────────────── */}
   <div class="border-t border-border-subtle">
      <Container width="default">
         <div
            class="py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3"
         >
            <p class="text-xs text-fg-subtle">© Trace Machina {year}</p>
            <p class="text-xs text-fg-subtle font-mono">
               Built with NativeLink · v1.3
            </p>
         </div>
      </Container>
   </div>
</footer>

<script is:inline>
   (function () {
      const form = document.getElementById("footer-newsletter");
      if (!form) return;
      const input = form.querySelector("input[name='email']");
      const msg = document.getElementById("footer-newsletter-msg");
      const setMsg = (t, ok) => {
         if (!msg) return;
         msg.textContent = t;
         msg.className =
            "text-xs min-h-[1rem] " + (ok ? "text-brand" : "text-[color:var(--color-danger)]");
      };
      form.addEventListener("submit", async (ev) => {
         ev.preventDefault();
         const email = (input && input.value || "").trim();
         if (!email) {
            setMsg("Please enter your email.", false);
            return;
         }
         setMsg("", true);
         try {
            const res = await fetch("/api/mail.json", {
               method: "POST",
               headers: { "Content-Type": "application/json" },
               body: JSON.stringify({ email }),
            });
            const data = await res.json().catch(() => ({}));
            if (res.ok) {
               input.value = "";
               setMsg(data.message || "Thanks — you're subscribed.", true);
            } else {
               setMsg(data.error || "Failed to subscribe. Try again later.", false);
            }
         } catch (_) {
            setMsg("Network error. Try again later.", false);
         }
      });
   })();
</script>
