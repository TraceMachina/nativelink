---
/**
 * Container — the centered content band inside a full-bleed Section.
 *
 *   <Section>           ← full-bleed: background, padding-y, no width cap
 *      <Container>      ← max-width 1440px, centered with mx-auto
 *         ... cards / hero text / grids ...
 *      </Container>
 *   </Section>
 *
 * The Section provides the surface (background colour / gradient / divider)
 * that runs edge-to-edge of the viewport. Container holds the content in a
 * comfortable centered band — wide enough to feel intentional on 14"–27"
 * displays, narrow enough that cards don't stretch into long lines on a 4K
 * monitor.
 *
 * For internal text-line readability (hero leads, paragraphs of body copy),
 * use the `narrow` or `prose` variants on a wrapping element OR add a
 * `max-w-2xl` etc. directly on the heading or paragraph — that way the
 * cards/grids around it still use the full Container width.
 */
interface Props {
   width?: "default" | "narrow" | "prose";
   class?: string;
   id?: string;
   as?: keyof HTMLElementTagNameMap;
}
const {
   width = "default",
   class: className,
   id,
   as = "div",
}: Props = Astro.props;

/* Internal padding scales with viewport so content doesn't slam against
 * the edges on narrow screens. On wide screens the max-width takes over
 * and the empty margin is just `(viewport - max-width) / 2`. */
const innerPadding = "px-6 sm:px-8 lg:px-10";

const widths: Record<NonNullable<Props["width"]>, string> = {
   default: `w-full max-w-[1440px] mx-auto ${innerPadding}`,
   narrow: `w-full max-w-[64rem] mx-auto ${innerPadding}`, /* ~1024px */
   prose: `w-full max-w-[44rem] mx-auto ${innerPadding}`, /* ~704px */
};

const Tag = as;
---

<Tag class:list={[widths[width], className]} id={id}>
   <slot />
</Tag>
