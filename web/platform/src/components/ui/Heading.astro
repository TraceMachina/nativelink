---
/**
 * Display + heading scale. `size` controls the visual weight; `as` controls the
 * semantic element so visual size and semantic order can diverge cleanly.
 *
 *   <Heading as="h1" size="display"> ... </Heading>
 *   <Heading as="h2" size="h2"> ... </Heading>
 */
interface Props {
   as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
   size?: "display" | "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
   tone?: "default" | "muted" | "gradient";
   class?: string;
   id?: string;
}
const {
   as = "h2",
   size,
   tone = "default",
   class: className,
   id,
}: Props = Astro.props;

const resolvedSize: NonNullable<Props["size"]> = size ?? as;

const sizes: Record<NonNullable<Props["size"]>, string> = {
   display: "text-display",
   h1: "text-h1",
   h2: "text-h2",
   h3: "text-h3",
   h4: "text-h4",
   h5: "text-h5",
   h6: "text-h6",
};

const tones: Record<NonNullable<Props["tone"]>, string> = {
   default: "text-fg",
   muted: "text-fg-muted",
   gradient: "text-gradient-brand",
};

const Tag = as;
---

<Tag
   class:list={[sizes[resolvedSize], tones[tone], className]}
   id={id}
>
   <slot />
</Tag>
