---
import Layout from "../../layouts/Layout.astro";
import { BookDownloadForm } from "../../components/qwik/components/book-download-form";
---

<Layout title="Extending Bazel to Its Full Potential - O'Reilly Book | NativeLink">
  <main class="bg-[rgb(248,247,244)] min-h-screen text-black">

    {/* Hero Section */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-5xl md:text-7xl font-bold text-black mb-6">
          Extending Bazel to Its Full Potential
        </h1>
        <p class="text-xl md:text-2xl text-[rgb(60,60,60)] max-w-4xl mx-auto">
          Leveraging Cloud and Parallelization to Ship Reliable Code Faster
        </p>
      </div>
    </div>

    {/* Book Details Section */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <div class="card-warm p-12">
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-3xl md:text-4xl font-bold text-black mb-6">
                Master Distributed Builds at Scale
              </h2>
              <p class="text-lg text-[rgb(60,60,60)] mb-8 leading-relaxed">
                Discover how to extend Bazel beyond its traditional boundaries. This comprehensive
                guide from O'Reilly Media explores advanced techniques for leveraging cloud infrastructure
                and parallelization to dramatically improve your build performance and reliability.
              </p>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <span class="text-black text-xl flex-shrink-0">✓</span>
                  <span class="text-lg text-black">Cloud-native build infrastructure design</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-black text-xl flex-shrink-0">✓</span>
                  <span class="text-lg text-black">Advanced parallelization strategies</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-black text-xl flex-shrink-0">✓</span>
                  <span class="text-lg text-black">Remote execution and caching best practices</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-black text-xl flex-shrink-0">✓</span>
                  <span class="text-lg text-black">New Bazel use cases and implementations</span>
                </li>
              </ul>
            </div>
            <div class="flex flex-col items-center">
              <div class="border-2 border-[rgb(220,220,220)] rounded-interactive overflow-hidden hover:-translate-y-1 transition-all duration-200">
                <img
                  src="https://endflakytests.com/oreilly_cover_photo.png"
                  alt="Extending Bazel to Its Full Potential - O'Reilly Book Cover"
                  class="w-full h-auto"
                />
              </div>
              <p class="text-sm text-[rgb(100,100,100)] mt-4">Published by O'Reilly Media</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Download Form Section */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-4xl mx-auto px-6">
        <BookDownloadForm client:visible />
      </div>
    </div>

    {/* Features Section */}
    <div class="section-spacing-major">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
          <div class="card-warm p-8 text-center">
            <div class="w-16 h-16 bg-black rounded-interactive flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black mb-3">Comprehensive Intro</h3>
            <p class="text-lg text-[rgb(60,60,60)]">
              From basics to advanced topics in distributed builds
            </p>
          </div>
          <div class="card-warm p-8 text-center">
            <div class="w-16 h-16 bg-black rounded-interactive flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black mb-3">Practical Examples</h3>
            <p class="text-lg text-[rgb(60,60,60)]">
              Real-world code samples and configurations
            </p>
          </div>
          <div class="card-warm p-8 text-center">
            <div class="w-16 h-16 bg-black rounded-interactive flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black mb-3">Performance Tips</h3>
            <p class="text-lg text-[rgb(60,60,60)]">
              Optimize your builds for maximum efficiency
            </p>
          </div>
        </div>
      </div>
    </div>

  </main>
</Layout>
