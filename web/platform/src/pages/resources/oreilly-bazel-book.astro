---
import Layout from "../../layouts/Layout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Lead from "@components/ui/Lead.astro";
import Card from "@components/ui/Card.astro";
import { BookDownloadForm } from "../../components/qwik/components/book-download-form";

const bullets = [
   "Cloud-native build infrastructure design",
   "Advanced parallelization strategies",
   "Remote execution and caching best practices",
   "New Bazel use cases and implementations",
];

const features = [
   {
      title: "Comprehensive intro",
      body: "From the basics through advanced topics in distributed builds.",
      icon: "book",
   },
   {
      title: "Practical examples",
      body: "Real-world code samples and configurations you can lift directly.",
      icon: "code",
   },
   {
      title: "Performance tips",
      body: "Concrete patterns for optimizing builds for maximum efficiency.",
      icon: "bolt",
   },
];
---

<Layout title="Extending Bazel to its Full Potential — NativeLink">
   {/* ── Hero ───────────────────────────────────────────────────────── */}
   <Section size="lg" tone="brand">
      <Container width="default">
         <div class="flex flex-col items-center text-center gap-6 max-w-3xl mx-auto">
            <Eyebrow>O'Reilly · Free download</Eyebrow>
            <Heading as="h1" size="display">
               Extending Bazel to its full potential.
            </Heading>
            <Lead class="mx-auto">
               Leveraging cloud and parallelization to ship reliable code
               faster.
            </Lead>
         </div>
      </Container>
   </Section>

   {/* ── Book detail ────────────────────────────────────────────────── */}
   <Section size="md">
      <Container width="default">
         <Card padding="lg" class="overflow-hidden">
            <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-16 items-center">
               <div class="flex flex-col gap-5">
                  <Eyebrow>What you'll learn</Eyebrow>
                  <Heading as="h2" size="h2">
                     Master distributed builds at scale.
                  </Heading>
                  <p class="text-fg-muted text-base leading-relaxed">
                     Discover how to extend Bazel beyond its traditional
                     boundaries. This comprehensive guide from O'Reilly Media
                     explores advanced techniques for leveraging cloud
                     infrastructure and parallelization to dramatically improve
                     your build performance and reliability.
                  </p>
                  <ul class="flex flex-col gap-3 mt-2">
                     {
                        bullets.map((b) => (
                           <li class="flex items-start gap-3 text-fg">
                              <svg
                                 class="h-4 w-4 mt-1 shrink-0 text-brand"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2.5"
                                 stroke-linecap="round"
                                 stroke-linejoin="round"
                                 aria-hidden="true"
                              >
                                 <path d="M20 6 9 17l-5-5" />
                              </svg>
                              <span>{b}</span>
                           </li>
                        ))
                     }
                  </ul>
               </div>
               <div class="flex flex-col items-center gap-3">
                  <div
                     class="rounded-lg overflow-hidden border border-border-subtle shadow-lg hover:-translate-y-0.5 transition-transform"
                  >
                     <img
                        src="https://endflakytests.com/oreilly_cover_photo.png"
                        alt="Extending Bazel to its Full Potential — O'Reilly Book Cover"
                        class="w-full max-w-xs h-auto block"
                     />
                  </div>
                  <p class="text-eyebrow text-fg-subtle">
                     Published by O'Reilly Media
                  </p>
               </div>
            </div>
         </Card>
      </Container>
   </Section>

   {/* ── Download form ──────────────────────────────────────────────── */}
   <Section size="md" tone="elevated">
      <Container width="narrow">
         <BookDownloadForm client:visible />
      </Container>
   </Section>

   {/* ── Features ───────────────────────────────────────────────────── */}
   <Section size="md">
      <Container width="default">
         <div class="grid md:grid-cols-3 gap-6">
            {
               features.map((f) => (
                  <Card padding="lg" class="flex flex-col items-start gap-5">
                     <div
                        class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand"
                        aria-hidden="true"
                     >
                        {f.icon === "book" && (
                           <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                           </svg>
                        )}
                        {f.icon === "code" && (
                           <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                           </svg>
                        )}
                        {f.icon === "bolt" && (
                           <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M13 10V3L4 14h7v7l9-11h-7z" />
                           </svg>
                        )}
                     </div>
                     <h3 class="text-h5 text-fg">{f.title}</h3>
                     <p class="text-fg-muted text-sm leading-relaxed">
                        {f.body}
                     </p>
                  </Card>
               ))
            }
         </div>
      </Container>
   </Section>
</Layout>
