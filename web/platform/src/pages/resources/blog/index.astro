---
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";

const allPosts = await getCollection("posts");
const newsPosts = allPosts.filter(post => post.data.tags?.includes('news'));
---

<Layout title="NativeLink News">
  <main class="bg-[rgb(248,247,244)] min-h-screen text-black">

    {/* Hero Section */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-7xl font-bold text-black">The Latest</h1>
      </div>
    </div>

    {/* Blog Posts Grid */}
    <div class="section-spacing-major">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
          {newsPosts
            .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
            .map((post) => (
              <a
                href={"/resources/blog/" + post.id}
                class="card-warm flex flex-col overflow-hidden hover:-translate-y-1 transition-all duration-200 no-underline"
              >
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title || "Blog post"}
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-6 flex flex-col justify-between flex-1">
                  <h3 class="text-xl font-bold text-black mb-4">{post.data.title}</h3>
                  <span class="text-lg text-black font-semibold">Read More →</span>
                </div>
              </a>
            ))}
        </div>
      </div>
    </div>

  </main>
</Layout>
