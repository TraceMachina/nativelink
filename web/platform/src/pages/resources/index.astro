---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const announcements = allPosts.filter(post => post.data.tags?.includes('announcements'));
const caseStudies = allPosts.filter(post => post.data.tags?.includes('case-studies'));
const blogPosts = allPosts.filter(post => post.data.tags?.includes('blog-posts'));

const pageTitle = "NativeLink Resources | Blog, Case Studies, Changelog";
---

<Layout title={pageTitle}>
  <main class="bg-[rgb(248,247,244)] min-h-screen text-black">

    {/* Hero Section */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-5xl md:text-7xl font-bold text-black">Resources</h1>
      </div>
    </div>

    {/* Books & Publications */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-5xl font-bold text-black mb-12">Books & Publications</h2>

        <a
          href="/resources/oreilly-bazel-book"
          class="card-warm p-8 flex flex-col md:flex-row gap-8 items-center hover:-translate-y-1 transition-all duration-200 no-underline max-w-3xl"
        >
          <div class="text-8xl flex-shrink-0">📘</div>
          <div class="flex flex-col gap-3">
            <h3 class="text-2xl font-bold text-black">Extending Bazel to Its Full Potential</h3>
            <p class="text-lg text-[rgb(60,60,60)]">Leveraging Cloud and Parallelization to Ship Reliable Code Faster</p>
            <span class="text-lg text-black font-semibold">Download Now →</span>
          </div>
        </a>
      </div>
    </div>

    {/* Case Studies */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-5xl font-bold text-black mb-12">Case Studies</h2>

        <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory">
          {caseStudies
            .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
            .map((post) => (
              <a
                href={"/resources/blog/" + post.id}
                class="card-warm flex-shrink-0 w-80 flex flex-col overflow-hidden hover:-translate-y-1 transition-all duration-200 no-underline snap-center"
              >
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title || "Case study"}
                    class="w-full h-48 object-contain bg-white"
                  />
                )}
                <div class="p-6 flex flex-col justify-between flex-1">
                  <h3 class="text-xl font-bold text-black mb-4">{post.data.title}</h3>
                  <span class="text-lg text-black font-semibold">Read More →</span>
                </div>
              </a>
            ))}
        </div>
      </div>
    </div>

    {/* Blog Posts */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-5xl font-bold text-black mb-12">Blog Posts</h2>

        <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory">
          {blogPosts
            .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
            .map((post) => (
              <a
                href={"/resources/blog/" + post.id}
                class="card-warm flex-shrink-0 w-80 flex flex-col overflow-hidden hover:-translate-y-1 transition-all duration-200 no-underline snap-center"
              >
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title || "Blog post"}
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-6 flex flex-col justify-between flex-1">
                  <h3 class="text-xl font-bold text-black mb-4">{post.data.title}</h3>
                  <span class="text-lg text-black font-semibold">Read More →</span>
                </div>
              </a>
            ))}
        </div>
      </div>
    </div>

    {/* Announcements */}
    <div class="section-spacing-major">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-5xl font-bold text-black mb-8">Announcements</h2>

        {/* Featured Video */}
        <div class="mb-12">
          <p class="text-lg text-[rgb(60,60,60)] mb-6">
            An awesome talk from one of TraceMachina's leading engineers Aaron Mondal
          </p>
          <div class="w-full max-w-4xl aspect-video border-2 border-[rgb(220,220,220)] rounded-interactive overflow-hidden">
            <iframe
              title="Hermetic Toolchain Creation with Local Remote Execution (LRE) & Nix - Aaron Mondal, NativeLink"
              class="w-full h-full"
              src="https://www.youtube-nocookie.com/embed/uokjTev8myk?rel=0"
              referrerpolicy="strict-origin-when-cross-origin"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
            ></iframe>
          </div>
        </div>

        {/* Announcement Cards */}
        <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory mb-12">
          {announcements
            .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
            .map((post) => (
              <a
                href={"/resources/blog/" + post.id}
                class="card-warm flex-shrink-0 w-80 flex flex-col overflow-hidden hover:-translate-y-1 transition-all duration-200 no-underline snap-center"
              >
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title || "Announcement"}
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-6 flex flex-col justify-between flex-1">
                  <h3 class="text-xl font-bold text-black mb-4">{post.data.title}</h3>
                  <span class="text-lg text-black font-semibold">Read More →</span>
                </div>
              </a>
            ))}
        </div>

        {/* CTA Button */}
        <div class="flex justify-center">
          <a
            href="/resources/blog"
            class="inline-flex bg-black text-white hover:bg-[rgb(40,40,40)] transition-colors duration-200 px-12 min-h-[48px] rounded-interactive justify-center items-center border-2 border-black font-semibold no-underline"
          >
            Go to Blog
          </a>
        </div>
      </div>
    </div>

  </main>
</Layout>
