---
import Layout from "../../layouts/Layout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Lead from "@components/ui/Lead.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const announcements = allPosts.filter((p) => p.data.tags?.includes("announcements"));
const caseStudies = allPosts.filter((p) => p.data.tags?.includes("case-studies"));
const blogPosts = allPosts.filter((p) => p.data.tags?.includes("blog-posts"));

const byDateDesc = (a: typeof allPosts[number], b: typeof allPosts[number]) =>
   new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
---

<Layout title="Resources — NativeLink">
   {/* ── Hero ───────────────────────────────────────────────────────── */}
   <Section size="lg" tone="brand">
      <Container width="default">
         <div class="flex flex-col items-start gap-6 max-w-2xl">
            <Eyebrow>Resources</Eyebrow>
            <Heading as="h1" size="display">
               Deep-tech writing for engineers who build the builds.
            </Heading>
            <Lead>
               Case studies, conference talks, and write-ups from the team
               building NativeLink — plus highlights from the broader community.
            </Lead>
         </div>
      </Container>
   </Section>

   {/* ── Books ──────────────────────────────────────────────────────── */}
   <Section size="md">
      <Container width="default">
         <div class="flex items-end justify-between gap-4 mb-8">
            <div class="flex flex-col gap-2">
               <Eyebrow>Books</Eyebrow>
               <Heading as="h2" size="h2">Books &amp; publications</Heading>
            </div>
         </div>
         <Card
            href="/resources/oreilly-bazel-book"
            interactive
            padding="lg"
         >
            <div class="flex flex-col sm:flex-row gap-6 items-start sm:items-center">
               <div
                  class="shrink-0 inline-flex h-16 w-16 items-center justify-center rounded-xl bg-brand/10 text-3xl"
                  aria-hidden="true"
               >
                  📘
               </div>
               <div class="flex flex-col gap-2 flex-1">
                  <Eyebrow tone="muted">O'Reilly · Free</Eyebrow>
                  <h3 class="text-h4 text-fg">
                     Extending Bazel to its full potential
                  </h3>
                  <p class="text-fg-muted text-sm leading-relaxed">
                     Leveraging cloud and parallelization to ship reliable code
                     faster.
                  </p>
               </div>
               <span class="text-eyebrow text-brand whitespace-nowrap">
                  Download →
               </span>
            </div>
         </Card>
      </Container>
   </Section>

   {/* ── Announcements: featured video + recent ─────────────────────── */}
   <Section size="lg" tone="elevated">
      <Container width="default">
         <div class="flex flex-col gap-3 mb-10">
            <Eyebrow>Announcements</Eyebrow>
            <Heading as="h2" size="h2">From the team</Heading>
            <Lead>
               A talk from one of Trace Machina's lead engineers, Aaron Mondal,
               plus the latest news from NativeLink.
            </Lead>
         </div>

         {/* Featured video */}
         <Card padding="none" class="overflow-hidden mb-8 max-w-4xl">
            <div class="aspect-video w-full">
               <iframe
                  title="Hermetic Toolchain Creation with Local Remote Execution (LRE) & Nix"
                  class="w-full h-full"
                  src="https://www.youtube-nocookie.com/embed/uokjTev8myk?rel=0"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
               ></iframe>
            </div>
         </Card>

         {/* Announcement cards */}
         {
            announcements.length > 0 && (
               <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                  {announcements.sort(byDateDesc).map((post) => (
                     <a
                        href={"/resources/blog/" + post.id}
                        class="no-style group/post flex flex-col rounded-xl overflow-hidden border border-border-subtle bg-card hover:border-border-strong hover:-translate-y-0.5 transition-all duration-300"
                     >
                        {post.data.image && (
                           <img
                              src={post.data.image}
                              alt=""
                              class="w-full h-44 object-cover bg-panel"
                              loading="lazy"
                           />
                        )}
                        <div class="p-5 flex flex-col gap-3 flex-1">
                           <h3 class="text-h6 text-fg leading-snug line-clamp-2">
                              {post.data.title}
                           </h3>
                           <span class="mt-auto text-eyebrow text-brand inline-flex items-center gap-2 group-hover/post:translate-x-0.5 transition-transform">
                              Read post →
                           </span>
                        </div>
                     </a>
                  ))}
               </div>
            )
         }
      </Container>
   </Section>

   {/* ── Case studies ───────────────────────────────────────────────── */}
   {
      caseStudies.length > 0 && (
         <Section size="md">
            <Container width="default">
               <div class="flex flex-col gap-3 mb-8">
                  <Eyebrow>Case studies</Eyebrow>
                  <Heading as="h2" size="h2">In production</Heading>
               </div>
               <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                  {caseStudies.sort(byDateDesc).map((post) => (
                     <a
                        href={"/resources/blog/" + post.id}
                        class="no-style group/post flex flex-col rounded-xl overflow-hidden border border-border-subtle bg-card hover:border-border-strong hover:-translate-y-0.5 transition-all duration-300"
                     >
                        {post.data.image && (
                           <img
                              src={post.data.image}
                              alt=""
                              class="w-full h-44 object-cover bg-panel"
                              loading="lazy"
                           />
                        )}
                        <div class="p-5 flex flex-col gap-3 flex-1">
                           <h3 class="text-h6 text-fg leading-snug line-clamp-2">
                              {post.data.title}
                           </h3>
                           <span class="mt-auto text-eyebrow text-brand inline-flex items-center gap-2 group-hover/post:translate-x-0.5 transition-transform">
                              Read study →
                           </span>
                        </div>
                     </a>
                  ))}
               </div>
            </Container>
         </Section>
      )
   }

   {/* ── Blog ───────────────────────────────────────────────────────── */}
   {
      blogPosts.length > 0 && (
         <Section size="md" tone="elevated">
            <Container width="default">
               <div class="flex items-end justify-between gap-4 mb-8">
                  <div class="flex flex-col gap-2">
                     <Eyebrow>Blog</Eyebrow>
                     <Heading as="h2" size="h2">Recent writing</Heading>
                  </div>
                  <Button href="/resources/blog" variant="secondary" arrow>
                     All posts
                  </Button>
               </div>
               <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                  {blogPosts.sort(byDateDesc).map((post) => (
                     <a
                        href={"/resources/blog/" + post.id}
                        class="no-style group/post flex flex-col rounded-xl overflow-hidden border border-border-subtle bg-card hover:border-border-strong hover:-translate-y-0.5 transition-all duration-300"
                     >
                        {post.data.image && (
                           <img
                              src={post.data.image}
                              alt=""
                              class="w-full h-44 object-cover bg-panel"
                              loading="lazy"
                           />
                        )}
                        <div class="p-5 flex flex-col gap-3 flex-1">
                           <h3 class="text-h6 text-fg leading-snug line-clamp-2">
                              {post.data.title}
                           </h3>
                           <span class="mt-auto text-eyebrow text-brand inline-flex items-center gap-2 group-hover/post:translate-x-0.5 transition-transform">
                              Read post →
                           </span>
                        </div>
                     </a>
                  ))}
               </div>
            </Container>
         </Section>
      )
   }
</Layout>

<style>
   /* Two-line clamp for card titles */
   .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
   }
</style>
