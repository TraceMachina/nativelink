---
import Layout from "../layouts/Layout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Lead from "@components/ui/Lead.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";

const channels = [
   {
      title: "Read the docs",
      description:
         "Setup guides, architecture deep-dives, and reference for every build system.",
      href: "/docs/introduction/setup",
      icon: "docs",
   },
   {
      title: "Join the Slack",
      description:
         "Talk to other operators, share configs, and get help from the core team.",
      href: "https://forms.gle/LtaWSixEC6bYi5xF7",
      icon: "slack",
   },
   {
      title: "Clone the repo",
      description:
         "NativeLink is open source. File issues, send PRs, or star us on GitHub.",
      href: "https://github.com/tracemachina/nativelink",
      icon: "github",
   },
];
---

<Layout title="Community — NativeLink">
   {/* ── Hero ───────────────────────────────────────────────────────── */}
   <Section size="lg" tone="brand">
      <Container width="default">
         <div class="flex flex-col items-center text-center gap-6 max-w-3xl mx-auto">
            <Eyebrow>Community</Eyebrow>
            <Heading as="h1" size="display">
               Join the people building NativeLink.
            </Heading>
            <Lead class="mx-auto">
               Operators, contributors, and the engineers who build NativeLink
               — all in the same room.
            </Lead>
         </div>
      </Container>
   </Section>

   {/* ── Channels ───────────────────────────────────────────────────── */}
   <Section size="md">
      <Container width="default">
         <div class="grid md:grid-cols-3 gap-6">
            {
               channels.map((c) => (
                  <Card
                     href={c.href}
                     interactive
                     padding="lg"
                     class="flex flex-col gap-5 text-left"
                  >
                     <div
                        class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand"
                        aria-hidden="true"
                     >
                        {c.icon === "docs" && (
                           <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M4 4h12a4 4 0 0 1 4 4v12H8a4 4 0 0 1-4-4z" />
                              <path d="M4 16a4 4 0 0 1 4-4h12" />
                              <path d="M8 8h6M8 12h4" />
                           </svg>
                        )}
                        {c.icon === "slack" && (
                           <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                              <rect x="3" y="11" width="6" height="2" rx="1" />
                              <rect x="11" y="15" width="2" height="6" rx="1" />
                              <rect x="15" y="11" width="6" height="2" rx="1" />
                              <rect x="11" y="3" width="2" height="6" rx="1" />
                              <path d="M9 9h2v2H9zM13 13h2v2h-2z" />
                           </svg>
                        )}
                        {c.icon === "github" && (
                           <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.01c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39s1.97.13 2.89.39c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.8 1.19 1.83 1.19 3.08 0 4.41-2.69 5.39-5.25 5.67.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56 4.57-1.52 7.86-5.83 7.86-10.91C23.5 5.65 18.35.5 12 .5Z" />
                           </svg>
                        )}
                     </div>
                     <div class="flex flex-col gap-2">
                        <h3 class="text-h5 text-fg">{c.title}</h3>
                        <p class="text-sm text-fg-muted leading-relaxed">
                           {c.description}
                        </p>
                     </div>
                     <span class="text-eyebrow inline-flex items-center gap-2 mt-auto">
                        Open
                        <span aria-hidden="true">→</span>
                     </span>
                  </Card>
               ))
            }
         </div>
      </Container>
   </Section>

   {/* ── Appreciation ───────────────────────────────────────────────── */}
   <Section size="lg" tone="elevated">
      <Container width="narrow">
         <div class="flex flex-col items-center text-center gap-6">
            <Eyebrow>Thank you</Eyebrow>
            <Heading as="h2" size="h2">We love our contributors.</Heading>
            <p class="text-lead text-fg-muted max-w-2xl">
               As a small token of appreciation, we'd love to send something
               special to active NativeLink community members and contributors.
               Fill out the form and our team will be in touch.
            </p>
            <Button
               href="https://forms.gle/LtaWSixEC6bYi5xF7"
               variant="primary"
               size="lg"
               arrow
               target="_blank"
               rel="noreferrer"
            >
               Fill out the form
            </Button>
         </div>
      </Container>
   </Section>
</Layout>
