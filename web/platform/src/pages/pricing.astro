---
import Layout from "../layouts/Layout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Heading from "@components/ui/Heading.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import Lead from "@components/ui/Lead.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";

const tiers = [
   {
      title: "Open Source",
      price: "Free",
      priceSub: "forever",
      tagline: "Everything you need to self-host NativeLink.",
      bullets: [
         "Self-hosted",
         "Community support on Slack",
         "Distributed scheduler & remote caching",
         "All build systems (Bazel, Buck2, Reclient, Pants)",
      ],
      cta: { label: "Get started", href: "/docs/introduction/setup", variant: "secondary" as const },
   },
   {
      title: "Cloud",
      price: "$1,000",
      priceSub: "/month",
      tagline: "Managed NativeLink. We run the infra, you ship.",
      featured: true,
      bullets: [
         "Fully managed cluster",
         "Automatic scaling & failover",
         "Production SLAs",
         "Onboarding support",
      ],
      cta: { label: "Start free trial", href: "https://dev.nativelink.com/", variant: "primary" as const },
   },
   {
      title: "Enterprise",
      price: "Custom",
      priceSub: "",
      tagline: "On-prem deployment with dedicated engineering.",
      bullets: [
         "Single-tenant on-prem deployment",
         "Dedicated engineer",
         "Custom SLAs & security review",
         "Autoscaling, GUI, build breakdown",
      ],
      cta: { label: "Request quote", href: "mailto:hello@nativelink.com", variant: "secondary" as const },
   },
];

type FeatureValue = string | true | false;
const features: Array<{ feature: string; oss: FeatureValue; enterprise: FeatureValue }> = [
   { feature: "Hosting", oss: "Self-hosted", enterprise: "Self-hosted or managed" },
   { feature: "Support", oss: "Community", enterprise: "Dedicated Engineer" },
   { feature: "Supported build systems", oss: "Bazel · Buck2 · Reclient · Pants", enterprise: "Bazel · Buck2 · Reclient · Pants" },
   { feature: "Operating systems", oss: "Linux, macOS", enterprise: "Linux, macOS, Windows" },
   { feature: "Org-wide sharing", oss: true, enterprise: true },
   { feature: "Distributed scheduler", oss: true, enterprise: true },
   { feature: "Remote caching", oss: true, enterprise: true },
   { feature: "Cross-compilation", oss: true, enterprise: true },
   { feature: "External storage (S3, Redis)", oss: true, enterprise: true },
   { feature: "Remote execution", oss: true, enterprise: true },
   { feature: "Autoscaling", oss: false, enterprise: true },
   { feature: "GUI dashboard", oss: false, enterprise: true },
   { feature: "Build action breakdown", oss: false, enterprise: true },
   { feature: "Live build updates", oss: false, enterprise: true },
];
---

<Layout title="Pricing — NativeLink">
   {/* ── Hero ───────────────────────────────────────────────────────── */}
   <Section size="lg" tone="brand">
      <Container width="default">
         <div class="flex flex-col items-center text-center gap-6 max-w-3xl mx-auto">
            <Eyebrow>Pricing</Eyebrow>
            <Heading as="h1" size="display">
               Built to scale with your infrastructure.
            </Heading>
            <Lead class="mx-auto">
               Start free, self-host, or let us run your build farm. Three tiers
               that grow with your team — no hidden fees, no per-user pricing.
            </Lead>
         </div>
      </Container>
   </Section>

   {/* ── Tiers ──────────────────────────────────────────────────────── */}
   <Section size="md">
      <Container width="default">
         <div class="grid md:grid-cols-3 gap-6">
            {
               tiers.map((tier) => (
                  <Card
                     tone={tier.featured ? "brand" : "default"}
                     padding="lg"
                     class="flex flex-col gap-6 relative"
                  >
                     {tier.featured && (
                        <span class="absolute right-4 top-4 text-eyebrow text-brand">
                           Recommended
                        </span>
                     )}
                     <div class="flex flex-col gap-2">
                        <h2 class="text-h4 text-fg">{tier.title}</h2>
                        <p class="text-sm text-fg-muted">{tier.tagline}</p>
                     </div>
                     <div class="flex items-baseline gap-1 pb-4 border-b border-border-subtle">
                        <span class="text-h2 text-fg font-semibold">
                           {tier.price}
                        </span>
                        {tier.priceSub && (
                           <span class="text-sm text-fg-muted">
                              {tier.priceSub}
                           </span>
                        )}
                     </div>
                     <ul class="flex flex-col gap-3 flex-1">
                        {tier.bullets.map((b) => (
                           <li class="flex items-start gap-3 text-sm text-fg">
                              <svg
                                 class="h-4 w-4 mt-0.5 shrink-0 text-brand"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2.5"
                                 stroke-linecap="round"
                                 stroke-linejoin="round"
                                 aria-hidden="true"
                              >
                                 <path d="M20 6 9 17l-5-5" />
                              </svg>
                              <span>{b}</span>
                           </li>
                        ))}
                     </ul>
                     <Button
                        href={tier.cta.href}
                        variant={tier.cta.variant}
                        size="md"
                        arrow
                        class="w-full"
                     >
                        {tier.cta.label}
                     </Button>
                  </Card>
               ))
            }
         </div>
      </Container>
   </Section>

   {/* ── Feature comparison ─────────────────────────────────────────── */}
   <Section size="lg">
      <Container width="default">
         <div class="flex flex-col items-start gap-3 mb-10">
            <Eyebrow>Compare</Eyebrow>
            <Heading as="h2" size="h2">
               Feature-for-feature comparison
            </Heading>
            <Lead>
               Everything that ships with each tier, side-by-side. Open Source
               and Enterprise share the same engine; Enterprise adds operational
               tooling on top.
            </Lead>
         </div>
         <div class="overflow-hidden rounded-xl border border-border-subtle bg-card">
            <table class="w-full text-left text-sm">
               <thead>
                  <tr class="border-b border-border-subtle bg-panel/40">
                     <th
                        class="px-5 py-4 w-[40%] text-eyebrow text-fg-muted font-medium"
                     >
                        Feature
                     </th>
                     <th
                        class="px-5 py-4 w-[30%] text-center text-eyebrow text-fg-muted font-medium"
                     >
                        Open Source
                     </th>
                     <th
                        class="px-5 py-4 w-[30%] text-center text-eyebrow text-fg-muted font-medium"
                     >
                        Enterprise
                     </th>
                  </tr>
               </thead>
               <tbody>
                  {
                     features.map((row, i) => (
                        <tr
                           class:list={[
                              "border-b border-border-subtle last:border-b-0",
                              i % 2 === 1 && "bg-bg/40",
                           ]}
                        >
                           <td class="px-5 py-4 text-fg font-medium">
                              {row.feature}
                           </td>
                           <td class="px-5 py-4 text-center text-fg-muted">
                              {row.oss === true ? (
                                 <svg
                                    class="inline-block h-4 w-4 text-brand"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-label="Included"
                                 >
                                    <path d="M20 6 9 17l-5-5" />
                                 </svg>
                              ) : row.oss === false ? (
                                 <svg
                                    class="inline-block h-4 w-4 text-fg-subtle"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-label="Not included"
                                 >
                                    <path d="M5 12h14" />
                                 </svg>
                              ) : (
                                 row.oss
                              )}
                           </td>
                           <td class="px-5 py-4 text-center text-fg-muted">
                              {row.enterprise === true ? (
                                 <svg
                                    class="inline-block h-4 w-4 text-brand"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-label="Included"
                                 >
                                    <path d="M20 6 9 17l-5-5" />
                                 </svg>
                              ) : row.enterprise === false ? (
                                 <svg
                                    class="inline-block h-4 w-4 text-fg-subtle"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-label="Not included"
                                 >
                                    <path d="M5 12h14" />
                                 </svg>
                              ) : (
                                 row.enterprise
                              )}
                           </td>
                        </tr>
                     ))
                  }
               </tbody>
            </table>
         </div>
      </Container>
   </Section>

   {/* ── FAQ teaser ─────────────────────────────────────────────────── */}
   <Section size="md" tone="elevated">
      <Container width="default">
         <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div class="flex flex-col gap-2">
               <Heading as="h2" size="h3">Have a question?</Heading>
               <p class="text-fg-muted">
                  Our team is happy to walk through pricing for your team or
                  workload.
               </p>
            </div>
            <div class="flex flex-wrap gap-3">
               <Button href="mailto:hello@nativelink.com" variant="primary" arrow>
                  Talk to sales
               </Button>
               <Button href="/community" variant="secondary">
                  Join community
               </Button>
            </div>
         </div>
      </Container>
   </Section>
</Layout>
