---
import Layout from "../layouts/Layout.astro";
import { FeatureTable } from "@qwik/components/table"
import { PricingCard } from "@qwik/components/cards";
---

<Layout title="NativeLink Pricing">
  <main class="bg-[rgb(248,247,244)] min-h-screen text-black">

    {/* Hero Section */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-black mb-4">
          Pricing built to scale with your infrastructure
        </h1>
      </div>
    </div>

    {/* Pricing Cards */}
    <div class="section-spacing-major section-divider">
      <div class="max-w-6xl mx-auto px-6">
        <PricingCard />
      </div>
    </div>

    {/* Feature Comparison */}
    <div class="section-spacing-major">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-5xl font-bold text-black mb-12">
          Feature Comparison
        </h2>
        <FeatureTable />
      </div>
    </div>

  </main>
</Layout>
