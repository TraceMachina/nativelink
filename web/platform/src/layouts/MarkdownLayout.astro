---
const { frontmatter, prevEntry, nextEntry, slug } = Astro.props;
const pubDate = new Date(frontmatter.pubDate);

const formattedDate = pubDate.toLocaleDateString('en-US', {
  day: '2-digit',
  month: 'long',
  year: 'numeric'
});
---

<div class="bg-[rgb(248,247,244)] min-h-screen text-black">
  <div class="max-w-4xl mx-auto px-6 py-24">

    <!-- Breadcrumbs -->
    <nav class="mb-8 text-sm">
      <ul class="flex items-center gap-3 text-[rgb(100,100,100)]">
        <li>
          <a href="/" class="hover:text-black transition-colors">Home</a>
        </li>
        <li>/</li>
        <li>
          <a href="/resources/blog" class="hover:text-black transition-colors">Blog</a>
        </li>
        <li>/</li>
        <li class="text-[rgb(60,60,60)]">
          {slug}
        </li>
      </ul>
    </nav>

    <!-- Article Header -->
    <article class="prose prose-lg max-w-none">
      {frontmatter.image && (
        <img
          src={frontmatter.image}
          alt={frontmatter.title || "Article image"}
          class="w-full rounded-interactive border-2 border-[rgb(220,220,220)] mb-8"
        />
      )}

      <h1 class="text-4xl md:text-5xl font-bold text-black mb-4">
        {frontmatter.title}
      </h1>

      <div class="text-base text-[rgb(100,100,100)] mb-12">
        {formattedDate} · {frontmatter.readTime}
      </div>

      <!-- Article Content -->
      <div class="text-lg text-[rgb(60,60,60)] leading-relaxed">
        <slot />
      </div>
    </article>

    <!-- Navigation -->
    <div class="mt-16 pt-8 border-t-2 border-[rgb(220,220,220)]">
      <div class="flex justify-between items-center gap-4">
        {prevEntry ? (
          <a
            href={`/resources/blog/${prevEntry.id}`}
            class="card-warm px-6 py-3 hover:-translate-y-1 transition-all duration-200 no-underline font-semibold"
          >
            ← Previous
          </a>
        ) : (
          <div></div>
        )}

        <a
          href="/resources/blog"
          class="bg-black text-white hover:bg-[rgb(40,40,40)] transition-colors duration-200 px-8 min-h-[48px] rounded-interactive flex items-center justify-center border-2 border-black font-semibold no-underline"
        >
          Back to Blog
        </a>

        {nextEntry ? (
          <a
            href={`/resources/blog/${nextEntry.id}`}
            class="card-warm px-6 py-3 hover:-translate-y-1 transition-all duration-200 no-underline font-semibold"
          >
            Next →
          </a>
        ) : (
          <div></div>
        )}
      </div>
    </div>

  </div>
</div>
