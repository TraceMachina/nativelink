{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "module": "esnext",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "extends": "@nativelink/config/tsconfig/base.json",
  "include": [
    "src/**/*"
  ]
}
